{
  "connectors": [
    {
      "name": "postgresql-transactions-source",
      "config": {
        "connector.class": "io.confluent.connect.jdbc.JdbcSourceConnector",
        "connection.url": "jdbc:postgresql://postgres-db:5432/transactions",
        "connection.user": "${file:/secrets/db-credentials.properties:postgres.user}",
        "connection.password": "${file:/secrets/db-credentials.properties:postgres.password}",
        "mode": "timestamp+incrementing",
        "incrementing.column.name": "transaction_id",
        "timestamp.column.name": "created_at",
        "topic.prefix": "postgres-",
        "table.whitelist": "transactions,payment_methods,merchant_info",
        "poll.interval.ms": 1000,
        "batch.max.rows": 1000,
        "validate.non.null": true,
        "transforms": "createKey,extractInt",
        "transforms.createKey.type": "org.apache.kafka.connect.transforms.ValueToKey",
        "transforms.createKey.fields": "transaction_id",
        "transforms.extractInt.type": "org.apache.kafka.connect.transforms.ExtractField$Key",
        "transforms.extractInt.field": "transaction_id",
        "key.converter": "org.apache.kafka.connect.converters.LongConverter",
        "value.converter": "io.confluent.connect.avro.AvroConverter",
        "value.converter.schema.registry.url": "http://schema-registry:8081",
        "value.converter.schemas.enable": true,
        "tasks.max": 3,
        "errors.tolerance": "all",
        "errors.log.enable": true,
        "errors.log.include.messages": true
      }
    },
    {
      "name": "mongodb-user-profiles-source",
      "config": {
        "connector.class": "com.mongodb.kafka.connect.MongoSourceConnector",
        "connection.uri": "mongodb://${file:/secrets/db-credentials.properties:mongo.user}:${file:/secrets/db-credentials.properties:mongo.password}@mongodb:27017",
        "database": "fraud_detection",
        "collection": "user_profiles",
        "topic.prefix": "mongo-",
        "pipeline": "[{\"$match\": {\"operationType\": {\"$in\": [\"insert\", \"update\", \"replace\"]}}}]",
        "change.stream.full.document": "updateLookup",
        "publish.full.document.only": true,
        "output.format.key": "json",
        "output.format.value": "json",
        "output.json.formatter": "com.mongodb.kafka.connect.source.json.formatter.SimplifiedJson",
        "key.converter": "org.apache.kafka.connect.storage.StringConverter",
        "value.converter": "io.confluent.connect.avro.AvroConverter",
        "value.converter.schema.registry.url": "http://schema-registry:8081",
        "tasks.max": 2
      }
    },
    {
      "name": "mysql-customer-data-source",
      "config": {
        "connector.class": "io.debezium.connector.mysql.MySqlConnector",
        "database.hostname": "mysql-db",
        "database.port": 3306,
        "database.user": "${file:/secrets/db-credentials.properties:mysql.user}",
        "database.password": "${file:/secrets/db-credentials.properties:mysql.password}",
        "database.server.id": 184054,
        "database.server.name": "mysql-cdc",
        "database.include.list": "customer_db",
        "table.include.list": "customer_db.customers,customer_db.accounts,customer_db.kyc_data",
        "database.history.kafka.bootstrap.servers": "kafka:9092",
        "database.history.kafka.topic": "schema-changes.customer",
        "include.schema.changes": true,
        "snapshot.mode": "initial",
        "snapshot.locking.mode": "minimal",
        "key.converter": "io.confluent.connect.avro.AvroConverter",
        "key.converter.schema.registry.url": "http://schema-registry:8081",
        "value.converter": "io.confluent.connect.avro.AvroConverter",
        "value.converter.schema.registry.url": "http://schema-registry:8081",
        "transforms": "unwrap,addPrefix",
        "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
        "transforms.unwrap.drop.tombstones": false,
        "transforms.addPrefix.type": "org.apache.kafka.connect.transforms.RegexRouter",
        "transforms.addPrefix.regex": ".*",
        "transforms.addPrefix.replacement": "mysql-$0",
        "tasks.max": 2
      }
    },
    {
      "name": "salesforce-crm-source",
      "config": {
        "connector.class": "io.confluent.salesforce.SalesforceCdcSourceConnector",
        "salesforce.instance": "https://your-instance.salesforce.com",
        "salesforce.username": "${file:/secrets/salesforce-credentials.properties:username}",
        "salesforce.password": "${file:/secrets/salesforce-credentials.properties:password}",
        "salesforce.password.token": "${file:/secrets/salesforce-credentials.properties:token}",
        "salesforce.object": "Account,Contact,Case",
        "salesforce.cdc.name": "FraudDetectionCDC",
        "kafka.topic": "salesforce-cdc",
        "connection.max.message.size": 10485760,
        "key.converter": "org.apache.kafka.connect.storage.StringConverter",
        "value.converter": "io.confluent.connect.avro.AvroConverter",
        "value.converter.schema.registry.url": "http://schema-registry:8081",
        "tasks.max": 1
      }
    },
    {
      "name": "s3-historical-data-source",
      "config": {
        "connector.class": "io.confluent.connect.s3.source.S3SourceConnector",
        "s3.region": "us-east-1",
        "s3.bucket.name": "fraud-detection-historical",
        "s3.credentials.provider.class": "com.amazonaws.auth.DefaultAWSCredentialsProviderChain",
        "format.class": "io.confluent.connect.s3.format.parquet.ParquetFormat",
        "confluent.topic.bootstrap.servers": "kafka:9092",
        "confluent.topic.replication.factor": 3,
        "mode": "GENERIC",
        "topics.dir": "historical-transactions",
        "topic.regex.list": "s3-historical-.*:historical-transactions/.*",
        "value.converter": "io.confluent.connect.avro.AvroConverter",
        "value.converter.schema.registry.url": "http://schema-registry:8081",
        "tasks.max": 4,
        "poll.interval.ms": 5000
      }
    },
    {
      "name": "http-fraud-intel-source",
      "config": {
        "connector.class": "io.confluent.connect.http.HttpSourceConnector",
        "http.api.url": "https://fraud-intel-api.example.com/v1/threats",
        "http.request.method": "GET",
        "http.request.headers": "Authorization: Bearer ${file:/secrets/api-credentials.properties:fraud.intel.token}",
        "http.timer.interval.ms": 60000,
        "kafka.topic": "external-fraud-intel",
        "http.response.record.path": "$.threats",
        "http.response.list.pointer": "/data",
        "key.converter": "org.apache.kafka.connect.storage.StringConverter",
        "value.converter": "io.confluent.connect.avro.AvroConverter",
        "value.converter.schema.registry.url": "http://schema-registry:8081",
        "tasks.max": 1
      }
    },
    {
      "name": "webhook-realtime-events-source",
      "config": {
        "connector.class": "io.confluent.connect.http.HttpSourceConnector",
        "http.api.url": "http://webhook-receiver:8080/events",
        "http.request.method": "GET",
        "http.timer.interval.ms": 100,
        "kafka.topic": "realtime-events",
        "http.response.record.path": "$",
        "key.converter": "org.apache.kafka.connect.storage.StringConverter",
        "value.converter": "org.apache.kafka.connect.json.JsonConverter",
        "value.converter.schemas.enable": false,
        "tasks.max": 2
      }
    },
    {
      "name": "jdbc-legacy-mainframe-source",
      "config": {
        "connector.class": "io.confluent.connect.jdbc.JdbcSourceConnector",
        "connection.url": "jdbc:db2://mainframe:50000/FRAUDDB",
        "connection.user": "${file:/secrets/db-credentials.properties:db2.user}",
        "connection.password": "${file:/secrets/db-credentials.properties:db2.password}",
        "mode": "bulk",
        "query": "SELECT * FROM LEGACY_TRANSACTIONS WHERE PROCESSED_FLAG = 'N'",
        "topic.prefix": "legacy-",
        "poll.interval.ms": 30000,
        "batch.max.rows": 5000,
        "value.converter": "io.confluent.connect.avro.AvroConverter",
        "value.converter.schema.registry.url": "http://schema-registry:8081",
        "tasks.max": 1
      }
    }
  ],
  "deployment_notes": {
    "prerequisites": [
      "Confluent Platform 7.5+ or Confluent Cloud",
      "Schema Registry configured and accessible",
      "Source databases accessible from Kafka Connect workers",
      "Appropriate database permissions (SELECT, REPLICATION for CDC)",
      "Secrets management system (e.g., Kubernetes Secrets, HashiCorp Vault)"
    ],
    "security_considerations": [
      "Use externalized secrets (never hardcode credentials)",
      "Enable SSL/TLS for database connections",
      "Implement network segmentation (VPC, security groups)",
      "Use least-privilege database accounts",
      "Enable audit logging for connector operations",
      "Rotate credentials regularly"
    ],
    "monitoring": [
      "Track connector status and lag metrics",
      "Monitor source database load impact",
      "Alert on connector failures or high error rates",
      "Track throughput and latency per connector",
      "Monitor Schema Registry compatibility checks"
    ],
    "scaling_guidelines": {
      "tasks.max": "Increase for higher throughput (test incrementally)",
      "batch.max.rows": "Tune based on message size and throughput needs",
      "poll.interval.ms": "Lower for near-real-time, higher to reduce load",
      "worker_count": "Scale Kafka Connect cluster horizontally for more connectors"
    }
  }
}