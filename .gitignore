# Ignore all markdown files except README.md and SCHEMA_EXPLANATION.md
*.md
!README.md
!SCHEMA_EXPLANATION.md

# Keep scripts directory
!scripts/
!scripts/*.py
!scripts/*.sh
!scripts/*.sql
!scripts/*.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Credentials (keep config.env template but ignore with actual credentials)
scripts/config.env

# Temporary files
*.tmp
*.bak

